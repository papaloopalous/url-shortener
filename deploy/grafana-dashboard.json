{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "auth-service RED metrics, business events and gRPC stats",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP RED metrics",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(auth_http_requests_total[1m])) by (path)",
          "legendFormat": "{{ path }}"
        }
      ],
      "title": "Request rate by path",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(auth_http_requests_total{status=~\"4..|5..\"}[1m])) by (path, status)",
          "legendFormat": "{{ status }} {{ path }}"
        }
      ],
      "title": "Error rate (4xx / 5xx)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(auth_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{ path }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(auth_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{ path }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(auth_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{ path }}"
        }
      ],
      "title": "Latency percentiles (p50 / p95 / p99)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Business events",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "token_reuse" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(auth_events_total[5m])) by (event)",
          "legendFormat": "{{ event }}"
        }
      ],
      "title": "Auth events per second",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "token_reuse" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ]}}
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        { "expr": "increase(auth_events_total{event=\"register_ok\"}[1h])", "legendFormat": "register_ok" },
        { "expr": "increase(auth_events_total{event=\"login_ok\"}[1h])", "legendFormat": "login_ok" },
        { "expr": "increase(auth_events_total{event=\"login_fail\"}[1h])", "legendFormat": "login_fail" },
        { "expr": "increase(auth_events_total{event=\"refresh_ok\"}[1h])", "legendFormat": "refresh_ok" },
        { "expr": "increase(auth_events_total{event=\"token_reuse\"}[1h])", "legendFormat": "token_reuse" },
        { "expr": "increase(auth_events_total{event=\"logout\"}[1h])", "legendFormat": "logout" }
      ],
      "title": "Event totals (last 1h)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(auth_events_total{event=\"login_fail\"}[5m])) / (sum(rate(auth_events_total{event=\"login_ok\"}[5m])) + sum(rate(auth_events_total{event=\"login_fail\"}[5m])))",
          "legendFormat": "Login failure rate"
        }
      ],
      "title": "Login failure rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "increase(auth_events_total{event=\"token_reuse\"}[5m])",
          "legendFormat": "Token reuse attempts"
        }
      ],
      "title": "Token reuse (last 5m) alert if > 0",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "gRPC ValidateToken",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(auth_grpc_requests_total[1m])) by (code)",
          "legendFormat": "{{ code }}"
        }
      ],
      "title": "gRPC request rate by status code",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(auth_grpc_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(auth_grpc_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "gRPC ValidateToken latency",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(auth_events_total{event=\"token_valid_grpc\"}[1m]))",
          "legendFormat": "valid"
        },
        {
          "expr": "sum(rate(auth_events_total{event=\"token_revoked_grpc\"}[1m]))",
          "legendFormat": "revoked"
        }
      ],
      "title": "gRPC token outcomes",
      "type": "timeseries"
    }

  ],

  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["auth", "go"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "auth-service",
  "uid": "auth-service-v1",
  "version": 1
}