{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "shortener-service observability: HTTP RED, cache, outbox, business events",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP RED (Rate · Errors · Duration)",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(shortener_http_requests_total[1m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(shortener_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(shortener_http_requests_total[1m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(shortener_http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "p50 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(shortener_http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "p95 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(shortener_http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "p99 {{path}}"
        }
      ],
      "title": "Request Duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Redirect & Cache",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(shortener_events_total{event=\"url_redirected\"}[1m])",
          "legendFormat": "Redirects/s"
        }
      ],
      "title": "Redirect Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(shortener_events_total{event=\"cache_hit\"}[1m]) / (rate(shortener_events_total{event=\"cache_hit\"}[1m]) + rate(shortener_events_total{event=\"cache_miss\"}[1m]))",
          "legendFormat": "Cache Hit Ratio"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Outbox / Kafka",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(shortener_events_total{event=\"outbox_published\"}[1m])",
          "legendFormat": "Published/s"
        },
        {
          "expr": "rate(shortener_events_total{event=\"outbox_failed\"}[1m])",
          "legendFormat": "Failed/s"
        }
      ],
      "title": "Outbox Publish Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "shortener_outbox_pending_total",
          "legendFormat": "Pending"
        }
      ],
      "title": "Outbox Pending (gauge)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Business Events",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 8,
      "targets": [
        {
          "expr": "rate(shortener_events_total{event=\"url_created\"}[1m])",
          "legendFormat": "url_created/s"
        },
        {
          "expr": "rate(shortener_events_total{event=\"url_redirected\"}[1m])",
          "legendFormat": "url_redirected/s"
        },
        {
          "expr": "rate(shortener_events_total{event=\"url_deleted\"}[1m])",
          "legendFormat": "url_deleted/s"
        }
      ],
      "title": "Business Events per Second",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["shortener", "go"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Shortener Service",
  "uid": "shortener-service-v1",
  "version": 1
}