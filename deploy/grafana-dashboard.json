{
  "description": "analytics-service: HTTP RED, worker pool, inbox dedup, click throughput",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP RED",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        { "expr": "sum(rate(analytics_http_requests_total[1m])) by (method, path)", "legendFormat": "{{method}} {{path}}" }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        { "expr": "sum(rate(analytics_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(analytics_http_requests_total[1m]))", "legendFormat": "Error Rate" }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(analytics_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(analytics_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(analytics_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ],
      "title": "Latency p50/p95/p99",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Worker Pool",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "analytics_worker_active", "legendFormat": "Active workers" }
      ],
      "title": "Active Workers (gauge)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 10 },
      "id": 5,
      "targets": [
        { "expr": "rate(analytics_events_total{event=\"click_processed\"}[1m])", "legendFormat": "processed/s" },
        { "expr": "rate(analytics_events_total{event=\"click_duplicate\"}[1m])", "legendFormat": "duplicate/s" },
        { "expr": "rate(analytics_events_total{event=\"click_failed\"}[1m])", "legendFormat": "failed/s" }
      ],
      "title": "Click Events per Second",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        { "expr": "rate(analytics_events_total{event=\"cache_hit\"}[1m]) / (rate(analytics_events_total{event=\"cache_hit\"}[1m]) + rate(analytics_events_total{event=\"cache_miss\"}[1m]))", "legendFormat": "Cache Hit Ratio" }
      ],
      "title": "Stats Cache Hit Ratio",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "targets": [
        { "expr": "rate(analytics_events_total{event=\"cache_hit\"}[1m])", "legendFormat": "cache_hit/s" },
        { "expr": "rate(analytics_events_total{event=\"cache_miss\"}[1m])", "legendFormat": "cache_miss/s" }
      ],
      "title": "Cache Hit vs Miss Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["analytics", "go"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Analytics Service",
  "uid": "analytics-service-v1",
  "version": 1
}